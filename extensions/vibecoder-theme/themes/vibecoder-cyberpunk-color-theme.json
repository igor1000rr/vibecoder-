	"tokenColors": [
		{
			"scope": [
				"comment",
				"punctuation.definition.comment",
				"string.comment"
			],
			"settings": {
				"foreground": "#6b6680",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"string",
				"string.quoted",
				"string.template"
			],
			"settings": {
				"foreground": "#a8ff85"
			}
		},
		{
			"scope": [
				"constant.numeric",
				"constant.language",
				"constant.character.escape"
			],
			"settings": {
				"foreground": "#ffb74d"
			}
		},
		{
			"scope": [
				"constant.language.boolean",
				"constant.language.null",
				"constant.language.undefined"
			],
			"settings": {
				"foreground": "#ff85d6",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"keyword",
				"keyword.control",
				"keyword.operator.new",
				"keyword.operator.expression",
				"keyword.operator.logical",
				"storage.type",
				"storage.modifier"
			],
			"settings": {
				"foreground": "#ff3cc8",
				"fontStyle": "bold"
			}
		},
		{
			"scope": [
				"keyword.operator",
				"punctuation.separator"
			],
			"settings": {
				"foreground": "#ff85d6"
			}
		},
		{
			"scope": [
				"entity.name.function",
				"meta.function-call",
				"support.function",
				"variable.function"
			],
			"settings": {
				"foreground": "#00f0ff"
			}
		},
		{
			"scope": [
				"entity.name.class",
				"entity.name.type",
				"entity.name.namespace",
				"entity.other.inherited-class",
				"support.class",
				"support.type"
			],
			"settings": {
				"foreground": "#a855f7",
				"fontStyle": "bold"
			}
		},
		{
			"scope": [
				"entity.name.tag",
				"meta.tag"
			],
			"settings": {
				"foreground": "#ff3cc8"
			}
		},
		{
			"scope": [
				"entity.other.attribute-name",
				"meta.tag entity.other.attribute-name"
			],
			"settings": {
				"foreground": "#ffb74d",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"variable",
				"variable.other",
				"variable.parameter"
			],
			"settings": {
				"foreground": "#e8e6f0"
			}
		},
		{
			"scope": [
				"variable.language",
				"variable.language.this",
				"variable.language.self"
			],
			"settings": {
				"foreground": "#ff85d6",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"meta.property.object",
				"variable.other.property",
				"variable.other.object.property"
			],
			"settings": {
				"foreground": "#85f0ff"
			}
		},
		{
			"scope": [
				"markup.heading",
				"markup.heading punctuation.definition.heading",
				"entity.name.section"
			],
			"settings": {
				"foreground": "#ff3cc8",
				"fontStyle": "bold"
			}
		},
		{
			"scope": [
				"markup.bold",
				"markup.bold string"
			],
			"settings": {
				"foreground": "#00f0ff",
				"fontStyle": "bold"
			}
		},
		{
			"scope": [
				"markup.italic"
			],
			"settings": {
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"markup.inline.raw",
				"markup.fenced_code.block"
			],
			"settings": {
				"foreground": "#a8ff85"
			}
		},
		{
			"scope": [
				"markup.underline.link",
				"markup.underline.link.image"
			],
			"settings": {
				"foreground": "#00f0ff",
				"fontStyle": "underline"
			}
		},
		{
			"scope": [
				"markup.list",
				"punctuation.definition.list_item.markdown"
			],
			"settings": {
				"foreground": "#ff85d6"
			}
		},
		{
			"scope": [
				"invalid",
				"invalid.illegal"
			],
			"settings": {
				"foreground": "#ff5c8a",
				"fontStyle": "underline"
			}
		},
		{
			"scope": [
				"diff.header"
			],
			"settings": {
				"foreground": "#ff3cc8"
			}
		},
		{
			"scope": [
				"diff.inserted"
			],
			"settings": {
				"foreground": "#7aff5c"
			}
		},
		{
			"scope": [
				"diff.deleted"
			],
			"settings": {
				"foreground": "#ff5c8a"
			}
		},
		{
			"scope": [
				"diff.changed"
			],
			"settings": {
				"foreground": "#ffb74d"
			}
		}
	]
}
